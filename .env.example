# Copie para .env e preencha com valores reais. .env nunca é versionado.

# Chave da API da Anthropic (console.anthropic.com), usada pela explicação
# em linguagem natural na tela Resumo. Sem essa variável, o recurso fica
# indisponível mas o resto do sistema funciona normalmente.
ANTHROPIC_API_KEY=
